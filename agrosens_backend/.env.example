# ============================================================
# AGROSENS BACKEND - CONFIGURACIÓN DE AMBIENTE
# ============================================================

# NODE ENVIRONMENT
NODE_ENV=development
PORT=3000

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrosens_db
DB_USER=agrosens_user
DB_PASSWORD=your_secure_password_here
DB_SSL=false

# ============================================================
# JWT CONFIGURATION
# ============================================================
JWT_SECRET=your_very_secure_jwt_secret_key_change_in_production_min_32_chars
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ============================================================
# FIREBASE CONFIGURATION (Para notificaciones push)
# ============================================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=your_firebase_database_url

# ============================================================
# CORS CONFIGURATION
# ============================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ============================================================
# API CONFIGURATION
# ============================================================
API_TIMEOUT=30000
MAX_REQUEST_SIZE=50mb

# ============================================================
# WEATHER API (Para enriquecimiento de predicciones)
# ============================================================
WEATHER_API_KEY=your_openweather_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ============================================================
# SENSORES - HEARTBEAT CONFIGURATION
# ============================================================
SENSOR_HEARTBEAT_INTERVAL_MINUTES=15
SENSOR_OFFLINE_THRESHOLD_MINUTES=30

# ============================================================
# ALERTAS - CONFIGURACIÓN
# ============================================================
ALERT_CHECK_INTERVAL_SECONDS=300
PREDICTION_WINDOW_MINUTES=120
STRESS_PROBABILITY_THRESHOLD=80

# ============================================================
# EMAIL CONFIGURATION (Opcional - para notificaciones por email)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@agrosens.com
